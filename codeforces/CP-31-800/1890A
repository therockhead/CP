#include <bits/stdc++.h>
using namespace std;
#define pb push_back
#define ll long long
#define MAX 1e9

int main () {
  int tt;
  cin >> tt;
  while (tt--) {
    int n;
    cin >> n;
    set<int> v;
    int freq[100000] = {0};
    int odd_cnt = 0;
    int even_cnt = 0;
    for (int i = 0; i < n; i++) {
      int val; cin >> val;
      if (val % 2 == 0) even_cnt++;
      else odd_cnt++;
      v.insert(val);
      freq[val]++;
    }
    if (v.size() > 2) {
      cout << "NO\n";
    }
    else if (v.size() == 2){
      if (freq[*next(v.begin(), 0)] >= n/2 && freq[*next(v.begin(), 1)] >= n/2) {
        cout << "YES\n";
      }
      else if (even_cnt == odd_cnt) {
        cout << "YES\n";
      }
      else if (even_cnt == n/2 || odd_cnt == n/2) cout << "YES\n"; 
      else cout << "NO\n";
    }
    else if (v.size() == 1) {
      cout << "YES\n";
    }
    else {
      cout << "NO\n";
    }
    
       
  }  

  return 0;
}
