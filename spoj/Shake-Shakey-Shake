#include <bits/stdc++.h>
using namespace std;
 
#define getsuga ios::sync_with_stdio(false);
#define tensho cin.tie(nullptr);
using ll = long long;
 
int n, k; // box, people
int box[50005];
int ok(int m) {
  ll cnt = 0;
  for (int i = 0; i < n; i++) {
    cnt += box[i] / m;
  }
  return cnt >= k;
 }

int main() {
getsuga tensho;

#ifndef ONLINE_JUDGE
    freopen("input.txt", "r", stdin);
    freopen("output.txt", "w", stdout);
#endif
int tt;
cin >> tt;
while (tt--) {

  cin >> n >> k;
  // int box[n];
  for (int i = 0; i < n; i++) {
    cin >> box[i];
  }

  int l = 1, r = 1e9, ans = 0;
  while (l <= r) {
    int mid = l + (r - l)/2;
    if (ok(mid)) {
      ans = mid;
      l = mid + 1;
    } else {
      r = mid - 1;
    }
  }
  cout << ans << '\n';
}
  
  return 0;
}
